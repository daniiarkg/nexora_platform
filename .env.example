APP_ENV=development
PUBLIC_APP_URL=http://localhost:3000
API_PORT=8080

DATABASE_URL=postgres://nexora:nexora@localhost:5432/nexora?sslmode=disable
VALKEY_URL=redis://localhost:6379/0

ALLOWED_ORIGINS=http://localhost:3000
ADMIN_API_TOKEN=replace-with-long-random-token

SESSION_COOKIE_NAME=nexora_session
SESSION_TTL_HOURS=720
EMAIL_CONFIRMATION_TTL_HOURS=24
PASSWORD_RESET_TTL_MINUTES=30
AUTH_ACCESS_KEYS=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

GEMINI_API_KEY=replace-with-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-password-if-needed
SMTP_APP_PASSWORD=your-gmail-app-password
SMTP_FROM="Nexora Support <support@nexora.kg>"
SMTP_FROM_OPTIONS="Nexora Support <support@nexora.kg>"
SMTP_ADMIN_RECIPIENTS=admin@example.com

PAYMENT_PROVIDER=unselected
PAYMENT_WEBHOOK_SECRET=replace-after-mor-selection

API_INTERNAL_URL=http://backend:8080
NEXT_PUBLIC_API_URL=
