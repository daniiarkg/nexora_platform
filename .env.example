SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-gmail-address@gmail.com
SMTP_PASSWORD=your-gmail-password-if-needed
SMTP_APP_PASSWORD=your-gmail-app-password
SMTP_FROM="Nexora Support <support@nexora.kg>"
SMTP_FROM_OPTIONS="Nexora Support <support@nexora.kg>"
SMTP_ADMIN_RECIPIENTS=admin@example.com

PAYMENT_PROVIDER=unselected
PAYMENT_WEBHOOK_SECRET=replace-after-mor-selection

NEXT_PUBLIC_API_URL=http://localhost:8080
