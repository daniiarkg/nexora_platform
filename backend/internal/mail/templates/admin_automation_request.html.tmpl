{{define "content"}}
<h1 style="margin:0 0 12px;color:#ffffff;font-size:28px;line-height:1.18;font-weight:700;letter-spacing:0;">Новая заявка на автоматизацию</h1>
<p style="margin:0 0 24px;color:#bec9c3;font-size:15px;line-height:1.65;">Клиент отправил демонстрационный граф. Заявка уже сохранена в админке Nexora.</p>

<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin:0 0 22px;background:#1c1b1b;border:1px solid rgba(255,255,255,.06);border-radius:14px;">
  <tr>
    <td style="padding:18px;">
      <p style="margin:0 0 6px;color:#88938d;font-size:12px;line-height:1.4;">Проект</p>
      <p style="margin:0;color:#ffffff;font-size:18px;line-height:1.35;font-weight:650;">{{.RequestTitle}}</p>
    </td>
  </tr>
  <tr>
    <td style="padding:0 18px 18px;color:#bec9c3;font-size:14px;line-height:1.6;">{{.RequestDescription}}</td>
  </tr>
</table>

<table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin:0 0 24px;border-collapse:separate;border-spacing:0 10px;">
  <tr>
    <td style="padding:13px 14px;background:#2a2a2a;border-radius:12px;color:#88938d;font-size:12px;width:36%;">Клиент</td>
    <td style="padding:13px 14px;background:#2a2a2a;border-radius:12px;color:#e5e2e1;font-size:13px;">{{.CustomerName}} &lt;{{.CustomerEmail}}&gt;</td>
  </tr>
  <tr>
    <td style="padding:13px 14px;background:#2a2a2a;border-radius:12px;color:#88938d;font-size:12px;">Компания</td>
    <td style="padding:13px 14px;background:#2a2a2a;border-radius:12px;color:#e5e2e1;font-size:13px;">{{.CustomerCompany}}</td>
  </tr>
  <tr>
    <td style="padding:13px 14px;background:#2a2a2a;border-radius:12px;color:#88938d;font-size:12px;">Граф</td>
    <td style="padding:13px 14px;background:#2a2a2a;border-radius:12px;color:#e5e2e1;font-size:13px;">{{.GraphNodeCount}} узлов, {{.GraphEdgeCount}} связей</td>
  </tr>
</table>

<a href="{{.ActionURL}}" style="display:inline-block;padding:14px 18px;border-radius:10px;background:#00674F;color:#ffffff;text-decoration:none;font-size:14px;font-weight:600;">Открыть в админке</a>
{{end}}
